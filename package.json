{
  "name": "meal-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3737",
    "build": "next build",
    "start": "next start --port 3737",
    "test": "vitest run --config vitest.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "npx tsx prisma/seed.ts",
    "db:seed:performance": "tsx scripts/seedLogHistoryPerformance.ts",
    "db:reset": "rm -f prisma/dev.db && prisma db push && npx tsx prisma/seed.ts",
    "clean": "rm -rf node_modules .next prisma/dev.db prisma/dev.db-journal",
    "setup": "npm install && npx prisma generate && npx prisma db push && npx tsx prisma/seed.ts",
    "lint": "eslint .",
    "test:performance": "tsx tests/performance/logHistory.performance.spec.ts",
    "analyze:security": "mkdir -p reports && semgrep scan --config auto --json > reports/semgrep.json || true",
    "analyze:lint": "mkdir -p reports && eslint . --format json --output-file reports/eslint.json || true",
    "analyze:dependencies": "mkdir -p reports && npm audit --json > reports/npm-audit.json || true",
    "analyze:static": "npm run analyze:security && npm run analyze:lint && npm run analyze:dependencies"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "bcrypt": "^6.0.0",
    "next": "16.2.9",
    "prisma": "^6.19.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@tailwindcss/postcss": "^4",
    "@types/autocannon": "^7.12.7",
    "@types/bcrypt": "^6.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.4",
    "autocannon": "^8.0.0",
    "better-sqlite3": "^12.10.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "fast-check": "^4.8.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.4"
  }
}
